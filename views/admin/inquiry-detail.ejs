
<div class="admin-page-header">
    <h2>询盘详情</h2>
    <p>查看客户询盘的完整信息</p>
</div>

<div class="admin-card">
    <div class="inquiry-detail">
        <div class="detail-row">
            <span class="detail-label">询盘ID：</span>
            <span class="detail-value"><%= inquiry.id %></span>
        </div>
        <div class="detail-row">
            <span class="detail-label">提交时间：</span>
            <span class="detail-value"><%= new Date(inquiry.created_at).toLocaleString('zh-CN') %></span>
        </div>
        <div class="detail-row">
            <span class="detail-label">客户姓名：</span>
            <span class="detail-value"><%= inquiry.name %></span>
        </div>
        <div class="detail-row">
            <span class="detail-label">联系电话：</span>
            <span class="detail-value"><%= inquiry.phone %></span>
        </div>
        <div class="detail-row">
            <span class="detail-label">电子邮箱：</span>
            <span class="detail-value"><%= inquiry.email || '-' %></span>
        </div>
        <div class="detail-row">
            <span class="detail-label">公司名称：</span>
            <span class="detail-value"><%= inquiry.company || '-' %></span>
        </div>
        <div class="detail-row">
            <span class="detail-label">咨询产品：</span>
            <span class="detail-value"><%= inquiry.product_name || '通用咨询' %></span>
        </div>
        <div class="detail-row">
            <span class="detail-label">需求数量：</span>
            <span class="detail-value"><%= inquiry.quantity || '-' %></span>
        </div>
        <div class="detail-row">
            <span class="detail-label">留言内容：</span>
            <span class="detail-value"><%= inquiry.message %></span>
        </div>
        <div class="detail-row">
            <span class="detail-label">处理状态：</span>
            <span class="detail-value">
                <span class="badge <%= inquiry.status === 'pending' ? 'badge-warning' : 'badge-success' %>">
                    <%= inquiry.status === 'pending' ? '待处理' : '已处理' %>
                </span>
            </span>
        </div>
    </div>

    <div class="detail-actions">
        <% if (inquiry.status === 'pending') { %>
        <button class="btn btn-success" onclick="markAsDone(<%= inquiry.id %>)">标记为已处理</button>
        <% } else { %>
        <button class="btn btn-warning" onclick="markAsPending(<%= inquiry.id %>)">标记为待处理</button>
        <% } %>
        <a href="/admin/inquiries" class="btn btn-secondary">返回列表</a>
    </div>
</div>

<style>
.inquiry-detail {
    margin-bottom: 30px;
}

.detail-row {
    display: flex;
    padding: 15px 0;
    border-bottom: 1px solid #eee;
}

.detail-row:last-child {
    border-bottom: none;
}

.detail-label {
    width: 120px;
    font-weight: bold;
    color: #495057;
}

.detail-value {
    flex: 1;
    color: #212529;
}

.detail-actions {
    display: flex;
    gap: 10px;
    padding-top: 20px;
    border-top: 1px solid #eee;
}
</style>

<script>
async function markAsDone(id) {
    if (!confirm('确定将此询盘标记为已处理？')) return;
    const res = await fetch('/admin/inquiries/' + id + '/status', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ status: 'done' })
    });
    const result = await res.json();
    if (result.success) location.reload();
}

async function markAsPending(id) {
    if (!confirm('确定将此询盘标记为待处理？')) return;
    const res = await fetch('/admin/inquiries/' + id + '/status', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ status: 'pending' })
    });
    const result = await res.json();
    if (result.success) location.reload();
}
</script>
