<div class="admin-page-header">
    <h2>控制台</h2>
    <p>欢迎回来，<%= user ? user.username : '管理员' %></p>
</div>

<div class="stats-cards">
    <div class="stat-card blue">
        <div class="stat-card-icon">📝</div>
        <div class="stat-card-info">
            <span class="stat-card-number"><%= stats.productCount %></span>
            <span class="stat-card-label">产品总数</span>
        </div>
    </div>
    <div class="stat-card orange">
        <div class="stat-card-icon">📥</div>
        <div class="stat-card-info">
            <span class="stat-card-number"><%= stats.pendingInquiryCount %></span>
            <span class="stat-card-label">待处理询盘</span>
        </div>
    </div>
</div>

<div class="admin-card">
    <div class="admin-card-header">
        <h3>最近询盘</h3>
        <a href="/admin/inquiries" class="btn-sm">查看全部</a>
    </div>
    <div class="admin-table-wrapper">
        <table class="admin-table">
            <thead>
                <tr>
                    <th>时间</th>
                    <th>姓名</th>
                    <th>电话</th>
                    <th>产品</th>
                    <th>状态</th>
                </tr>
            </thead>
            <tbody>
                <% if (recentInquiries.length === 0) { %>
                <tr><td colspan="5" class="text-center">暂无询盘</td></tr>
                <% } %>
                <% recentInquiries.forEach(item => { %>
                <tr>
                    <td><%= new Date(item.created_at).toLocaleString('zh-CN') %></td>
                    <td><%= item.name %></td>
                    <td><%= item.phone %></td>
                    <td><%= item.product_name || '通用咨询' %></td>
                    <td>
                        <span class="badge <%= item.status === 'pending' ? 'badge-warning' : 'badge-success' %>">
                            <%= item.status === 'pending' ? '待处理' : '已处理' %>
                        </span>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</div>

<div class="admin-card">
    <div class="admin-card-header">
        <h3>快捷操作</h3>
    </div>
    <div class="quick-actions">
        <a href="/admin/products" class="quick-action-item">
            <span class="icon">📝</span>
            <span>管理产品</span>
        </a>
        <a href="/admin/uploads" class="quick-action-item">
            <span class="icon">🖼️</span>
            <span>上传图片</span>
        </a>
        <a href="/admin/settings" class="quick-action-item">
            <span class="icon">⚙️</span>
            <span>网站设置</span>
        </a>
        <a href="/" target="_blank" class="quick-action-item">
            <span class="icon">🌐</span>
            <span>访问前台</span>
        </a>
    </div>
</div>
